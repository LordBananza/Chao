}


char x;
char y;
char length;
char height;
char button;


void checkDPad() {

			char oldX = x;
			char oldY = y;
			
			button = buttonUpPressed();
			
			if (button) {
				y = y - 1;
			}
			
			button = buttonDownPressed();
			
			if (button) {
				y = y + 1;
			}
			

		

		
			
			button = buttonLeftPressed();
			
			if (button) {
				x = x - 8;
			}
			
			button = buttonRightPressed();
			
			if (button) {
				x = x + 8;
			}
			
			if (oldX == x) {
			if (oldY == y) {
			
			return;
			}
			asm(nop);
			}
			draw(oldX, oldY, length, height, noChao);
			draw(x, y, length, height, Omochao);
		
		return;


}

void main() {

	char mainMode = 0;

	x = 16;
	y = 10;
	length = 16;
	height = 8;
	
	clearScreen();
	
	drawScreen(introScreen);
	
	while (1) {
		
		if (mainMode == 0) {
		button = buttonAPressed();
		
		
		if (button) {
			clearScreenSlow();
			mainMode = 1;
			
			x = 16;
			y = 10;
			length = 16;
			height = 8;
			
			draw(x, y, length, height, Omochao);
			
		}
		asm(nop);
		}
		
		if (mainMode == 1) {
			
			checkDPad();
			
		
		}
		
		button = buttonBPressed();
		if (button) {
			fillScreenSlow();
			drawScreen(introScreen);
			mainMode = 0;
		}
		
		buttonModePressed();
	}
	
	button = 1;

}


