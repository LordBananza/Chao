#include <buttons.h>
#include <display.h>

data Omochao() {
	asm(.byte %00000001,%10000000);
	asm(.byte %01111111,%11111110);
	asm(.byte %00000001,%10000000);
	asm(.byte %00000110,%01100000);
	asm(.byte %00001100,%00110000);
	asm(.byte %00001101,%10110000);
	asm(.byte %00001100,%00110000);
	asm(.byte %00000011,%11000000);

}

data noChao() {
	asm(.byte %00000000,%00000000);
	asm(.byte %00000000,%00000000);
	asm(.byte %00000000,%00000000);
	asm(.byte %00000000,%00000000);
	asm(.byte %00000000,%00000000);
	asm(.byte %00000000,%00000000);
	asm(.byte %00000000,%00000000);
	asm(.byte %00000000,%00000000);

}

data introScreen() {

	asm(.byte %00000000,%00000000,%00000000,%01000000,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00000000,%10000000,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%01000001,%00000000,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%01000010,%00100000,%00000000,%00000000);
