	asm(.byte %00000000,%00000000,%00100110,%01000000,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00010100,%00110000,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00001100,%00101000,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00000010,%01100100,%00000000,%00000000);
	asm(.byte %00000000,%00000001,%10000001,%10100010,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%01100001,%00100010,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00011010,%00100010,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00000100,%01000010,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00000000,%10000010,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00000001,%00000000,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00000010,%00000000,%00000000,%00000000);
	asm(.byte %00000000,%00000000,%00000000,%00000000,%00000000,%00000000);
	asm(.byte %00000000,%01110101,%00110001,%00001100,%11101110,%00000000);
	asm(.byte %00000000,%01000111,%01001010,%10001000,%11100100,%00000000);
	asm(.byte %00000000,%01000111,%01111010,%10001010,%10000100,%00000000);
	asm(.byte %00000000,%01110101,%01001001,%00001110,%10000100,%00000000);
