void main() {
	char x;
	
	clearScreen();
	
	drawScreen(introScreen);
	
	while (1) {
	
		x = buttonAPressed();
		
		if (x) {
			clearScreenSlow();
			
			x = 16;
			char y = 10;
			char length = 16;
			char height = 8;
			
			draw(x, y, length, height, Omochao);
			
		}
		
		
		
		/*if (9 <= 9) {
			clearScreenSlow();
		}
		
		if (9 < 8) {
			fillScreenSlow();
		}*/
		
		x = buttonBPressed();
		if (x) {
			fillScreenSlow();
			drawScreen(introScreen);
		}
		
		x = 0;
	}
	
	x = 1;

}


